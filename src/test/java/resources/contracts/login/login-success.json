{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "token": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "const": "Success"
    },
    "result": {
      "type": "string",
      "const": "User authorized successfully."
    }
  },
  "required": ["token", "status", "result"],
  "additionalProperties": true
}

